<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Freudenreiche Geheimnisse"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#5E8291"
        android:letterSpacing="0.08" />

    <TextView
        android:id="@+id/widget_g1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Die Verkündigung"
        android:textSize="12sp"
        android:textColor="#3B3830"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/widget_g2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Die Heimsuchung"
        android:textSize="12sp"
        android:textColor="#3B3830"
        android:layout_marginTop="3dp" />

    <TextView
        android:id="@+id/widget_g3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3. Die Geburt"
        android:textSize="12sp"
        android:textColor="#3B3830"
        android:layout_marginTop="3dp" />
</LinearLayout>
