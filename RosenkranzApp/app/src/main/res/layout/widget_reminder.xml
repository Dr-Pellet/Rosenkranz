<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_bg_accent"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rosenkranz"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.12" />

    <TextView
        android:id="@+id/widget_reminder_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Erinnerung: 20:00 Uhr"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_reminder_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Öffnen"
        android:textSize="11sp"
        android:textColor="#EEF3F5"
        android:layout_marginTop="6dp"
        android:background="@drawable/widget_button_bg"
        android:paddingHorizontal="14dp"
        android:paddingVertical="4dp" />
</LinearLayout>
