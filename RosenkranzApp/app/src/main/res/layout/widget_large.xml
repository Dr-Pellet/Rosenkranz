<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="18dp">

    <TextView
        android:id="@+id/widget_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Montag · Freudenreiche Geheimnisse"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#5E8291"
        android:letterSpacing="0.06"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/widget_d1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Die Verkündigung des Herrn"
        android:textSize="12sp"
        android:textColor="#3B3830"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_d2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Die Heimsuchung Mariens"
        android:textSize="12sp"
        android:textColor="#3B3830"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_d3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3. Die Geburt Christi"
        android:textSize="12sp"
        android:textColor="#3B3830"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_d4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4. Die Darstellung Jesu im Tempel"
        android:textSize="12sp"
        android:textColor="#3B3830"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_d5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5. Das Wiederfinden Jesu im Tempel"
        android:textSize="12sp"
        android:textColor="#3B3830"
        android:layout_marginTop="4dp" />
</LinearLayout>
